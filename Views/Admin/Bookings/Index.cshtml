@model List<Alakol.Models.Booking>
@using Alakol.Models.Enums

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Bookings</h2>

<table class="admin-table">
    <tr>
        <th>Guest Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Room Name</th>
        <th>GuestHouse Name</th>
        <th>Dates</th>
        <th>Status</th>
        <th>Actions</th>
    </tr>

    @foreach (var b in Model)
    {
        <tr>
            <td>@b.GuestName</td>
            <td>@b.GuestEmail</td>
            <td>@b.GuestPhone</td>
            <td>@b.Room?.Name</td>
            <td>@b.Room?.GuestHouse?.Name</td>
            <td>@b.CheckInDate.ToShortDateString() - @b.CheckOutDate.ToShortDateString()</td>

            <td>
                <span class="status @b.Status.ToString().ToLower()">
                    @b.Status
                </span>
            </td>

            <td class="actions">
                @if (b.Status == BookingStatus.Pending)
                {
                    <a class="btn btn-secondary" href="/Admin/Bookings/Approve/@b.Id">Approve</a>
                    <a class="btn btn-danger" href="/Admin/Bookings/Reject/@b.Id">Reject</a>
                }

                @if (b.Status == BookingStatus.Approved)
                {
                    <a class="btn btn-danger" href="/Admin/Bookings/Cancel/@b.Id">Cancel</a>
                }
            </td>
        </tr>
    }
</table>
