@model Alakol.Models.Room
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var guestHouses = ViewBag.GuestHouses as List<Alakol.Models.GuestHouse> ?? new List<Alakol.Models.GuestHouse>();
}

<h2>Edit Room</h2>

<form class="admin-form" method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div class="form-group">
        <label>Description</label>
        <textarea asp-for="Description"></textarea>
    </div>

    <div class="form-group">
        <label>Price</label>
        <input asp-for="PricePerNight" />
    </div>

    <div class="form-group">
        <label>Capacity</label>
        <input asp-for="Capacity" />
    </div>

    <div class="form-group">
        <label>GuestHouse</label>
        <select asp-for="GuestHouseId">
            @foreach (var gh in guestHouses)
            {
                <option value="@gh.Id">@gh.Name</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Add room images</label>
        <input type="file" name="images" accept="image/*" multiple />
    </div>

    <button class="btn btn-primary" type="submit">Save</button>

</form>

@if (Model.Images.Any())
{
    <div class="room-images">
        @foreach (var image in Model.Images)
        {
            <div class="image-wrapper">
                <img src="@image.ImageUrl" alt="@Model.Name" />
                <form method="post" action="/Admin/Rooms/DeleteImage">
                    <input type="hidden" name="imageId" value="@image.Id" />
                    <button class="delete-btn" type="submit">&times;</button>
                </form>
            </div>
        }
    </div>
}
