@model Alakol.DTOs.CreateBookingDto
@{
    ViewData["Title"] = "Booking";
    var rooms = ViewBag.Rooms as List<Alakol.Models.Room> ?? new List<Alakol.Models.Room>();
    var minDate = DateTime.Now.AddDays(3).ToString("yyyy-MM-dd");
    var maxDate = DateTime.Now.AddMonths(6).ToString("yyyy-MM-dd");
}

<section class="booking-section">
    <div class="booking-container booking-container-wide">
        <h1>Book Your Stay</h1>

        @if (ViewBag.SuccessMessage != null)
        {
            <div class="booking-success">@ViewBag.SuccessMessage</div>
        }

        <form class="booking-form" method="post">
            <div asp-validation-summary="ModelOnly" class="booking-error"></div>

            <input type="hidden" name="RoomId" id="selectedRoomId" value="@(Model.RoomId == 0 ? "" : Model.RoomId.ToString())" required />

            <div class="booking-room-grid">
                @foreach (var room in rooms)
                {
                    var image = room.Images.FirstOrDefault(i => i.IsMain) ?? room.Images.FirstOrDefault();
                    var selectedClass = Model.RoomId == room.Id ? "selected" : "";

                    <div class="booking-room-card @selectedClass" onclick="selectRoom(event, @room.Id)">
                        <div class="booking-room-image">
                            @if (image != null)
                            {
                                <img src="@image.ImageUrl" alt="@room.Name" />
                            }
                            else
                            {
                                <span>No image</span>
                            }
                        </div>

                        <div class="booking-room-body">
                            <h3>@room.Name</h3>
                            <p>@room.Description</p>
                            <p class="room-price">$@room.PricePerNight / night</p>
                            <p>Up to @room.Capacity guests</p>
                        </div>
                    </div>
                }
            </div>

            <div class="booking-fields-grid">
                <div class="form-group">
                    <label>Check-in date</label>
                    <input type="date" name="CheckIn" min="@minDate" max="@maxDate" value="@(Model.CheckInDate == default ? "" : Model.CheckInDate.ToString("yyyy-MM-dd"))" required />
                </div>

                <div class="form-group">
                    <label>Check-out date</label>
                    <input type="date" name="CheckOut" min="@minDate" max="@maxDate" value="@(Model.CheckOutDate == default ? "" : Model.CheckOutDate.ToString("yyyy-MM-dd"))" required />
                </div>

                <div class="form-group">
                    <label>Guest Name</label>
                    <input asp-for="GuestName" required />
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="GuestEmail" type="email" required />
                </div>

                <div class="form-group">
                    <label>Phone</label>
                    <input asp-for="GuestPhone" required />
                </div>
            </div>

            <button class="site-button" type="submit">Book Now</button>
        </form>
    </div>
</section>

<script>
    function selectRoom(event, id) {
        document.getElementById("selectedRoomId").value = id;

        document.querySelectorAll(".booking-room-card").forEach(function (card) {
            card.classList.remove("selected");
        });

        event.currentTarget.classList.add("selected");
    }
</script>
